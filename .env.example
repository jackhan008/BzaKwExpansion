AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---------------------------------------------------------------------------
# Azure Data Source
# ---------------------------------------------------------------------------

# Environment: local -> AzureCliCredential (az login), cloud -> ManagedIdentityCredential
APP_ENV=local

# Set to true to use Azure SQL + AI Search instead of local SQLite + FAISS
USE_AZURE_DATASOURCE=false

# Azure SQL Database
AZURE_SQL_SERVER=<your-server>.database.windows.net
AZURE_SQL_DATABASE=<your-database>
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server
AZURE_SQL_PORT=1433

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_VERSION=2024-05-01-preview

# AI Search index names per market (override defaults if needed)
# AZURE_SEARCH_INDEX_AU=keywords-au
# AZURE_SEARCH_INDEX_JP=keywords-jp
# AZURE_SEARCH_INDEX_IN=keywords-in
# AZURE_SEARCH_INDEX_SG=keywords-sg
# AZURE_SEARCH_INDEX_MY=keywords-my
# AZURE_SEARCH_INDEX_TH=keywords-th
# AZURE_SEARCH_INDEX_PH=keywords-ph
# AZURE_SEARCH_INDEX_ID=keywords-id
# AZURE_SEARCH_INDEX_VN=keywords-vn
# AZURE_SEARCH_INDEX_CN=keywords-cn

# AI Search index field names (override if your schema uses different names)
# AZURE_SEARCH_QUERY_FIELD=normalized_query
# AZURE_SEARCH_SRPV_FIELD=SRPV
# AZURE_SEARCH_ADCLICK_FIELD=AdClick
# AZURE_SEARCH_REVENUE_FIELD=revenue
# AZURE_SEARCH_TOP_K=100
